generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  username      String          @unique
  passwordHash  String
  createdAt     DateTime        @default(now())
  trainingHands TrainingHand[]
  progress      UserProgress[]
}

model TrainingHand {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  module        String   @default("preflop")
  heroCard1Rank String
  heroCard1Suit String
  heroCard2Rank String
  heroCard2Suit String
  flopCard1Rank String?                           
  flopCard1Suit String?                           
  flopCard2Rank String?                           
  flopCard2Suit String?                           
  flopCard3Rank String?                           
  flopCard3Suit String?
  turnCardRank  String?
  turnCardSuit  String?
  riverCardRank String?
  riverCardSuit String?
  villainRange  Int
  difficulty    Int
  pointsScored  Int?
  actualEquity         Float?
  repetitionStage      Int?
  repetitionAvailableAt DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  module      String
  difficulty  Int
  unlockedAt  DateTime @default(now())

  @@unique([userId, module, difficulty])
}
