generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  username      String          @unique
  passwordHash  String
  isPremium     Boolean         @default(false)
  isAdmin       Boolean         @default(false)
  createdAt     DateTime        @default(now())
  trainingHands TrainingHand[]
  progress      UserProgress[]
  achievements  Achievement[]
}

model Achievement {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  key      String
  earnedAt DateTime @default(now())

  @@unique([userId, key])
  @@index([userId])
}

model TrainingHand {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  guestId       String?
  module        String   @default("preflop")
  heroCard1Rank String?
  heroCard1Suit String?
  heroCard2Rank String?
  heroCard2Suit String?
  flopCard1Rank String?
  flopCard1Suit String?
  flopCard2Rank String?
  flopCard2Suit String?
  flopCard3Rank String?
  flopCard3Suit String?
  turnCardRank  String?
  turnCardSuit  String?
  riverCardRank String?
  riverCardSuit String?
  villainRange  Int?
  potSize       Int?
  betSize       Int?
  difficulty    Int
  pointsScored  Int?
  actualEquity         Float?
  repetitionStage      Int?
  repetitionAvailableAt DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PreGeneratedHand {
  id            String   @id @default(cuid())
  module        String
  heroHandType  String
  heroCard1Rank String
  heroCard1Suit String
  heroCard2Rank String
  heroCard2Suit String
  flopCard1Rank String?
  flopCard1Suit String?
  flopCard2Rank String?
  flopCard2Suit String?
  flopCard3Rank String?
  flopCard3Suit String?
  turnCardRank  String?
  turnCardSuit  String?
  riverCardRank String?
  riverCardSuit String?
  villainRange  Int
  equity        Float
  iterations    Int
  createdAt     DateTime @default(now())

  @@index([module, heroHandType])
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  module      String
  difficulty  Int
  unlockedAt  DateTime @default(now())

  @@unique([userId, module, difficulty])
}
