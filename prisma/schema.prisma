generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  username      String          @unique
  passwordHash  String
  emailVerified DateTime?
  isPremium     Boolean         @default(false)
  isAdmin       Boolean         @default(false)
  deletedAt     DateTime?
  createdAt     DateTime        @default(now())
  trainingHands TrainingHand[]
  rangeRounds   RangeTrainingRound[]
  progress      UserProgress[]
  achievements  Achievement[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  type      String   @default("email-verification")
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, type])
}

model Achievement {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  key      String
  earnedAt DateTime @default(now())

  @@unique([userId, key])
  @@index([userId])
}

model TrainingHand {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  guestId       String?
  module        String   @default("preflop")
  heroCard1Rank String?
  heroCard1Suit String?
  heroCard2Rank String?
  heroCard2Suit String?
  flopCard1Rank String?
  flopCard1Suit String?
  flopCard2Rank String?
  flopCard2Suit String?
  flopCard3Rank String?
  flopCard3Suit String?
  turnCardRank  String?
  turnCardSuit  String?
  riverCardRank String?
  riverCardSuit String?
  villainCard1Rank String?
  villainCard1Suit String?
  villainCard2Rank String?
  villainCard2Suit String?
  villainRange       Int?
  villainProfileId   String?
  villainPosition    Int?
  potSize            Int?
  betSize            Int?
  equityGuessIndex   Int?
  difficulty         Int
  pointsScored       Int?
  actualEquity         Float?
  repetitionStage      Int?
  repetitionAvailableAt DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PreGeneratedHand {
  id            String   @id @default(cuid())
  module        String
  heroHandType  String
  heroCard1Rank String
  heroCard1Suit String
  heroCard2Rank String
  heroCard2Suit String
  flopCard1Rank String?
  flopCard1Suit String?
  flopCard2Rank String?
  flopCard2Suit String?
  flopCard3Rank String?
  flopCard3Suit String?
  turnCardRank  String?
  turnCardSuit  String?
  riverCardRank String?
  riverCardSuit String?
  villainCard1Rank String?
  villainCard1Suit String?
  villainCard2Rank String?
  villainCard2Suit String?
  villainRange  Int?
  equity        Float
  iterations    Int
  createdAt     DateTime @default(now())

  @@index([module, heroHandType])
}

model HandEquityMatrix {
  handType   String   @id
  equity     Float
  iterations Int
  updatedAt  DateTime @updatedAt
}

model RangeTrainingRound {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  guestId        String?
  module         String   @default("preflop-ranges")
  difficulty     Int
  position       String
  handTypes      String
  correctAnswers String
  userAnswers    String?
  pointsScored   Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, module, difficulty])
  @@index([guestId, module, difficulty])
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  module      String
  difficulty  Int
  unlockedAt  DateTime @default(now())

  @@unique([userId, module, difficulty])
}

model VillainProfile {
  id          String                   @id @default(cuid())
  name        String
  slug        String                   @unique
  description String                   @db.Text
  isPublished Boolean                  @default(false)
  sortOrder   Int                      @default(0)
  traits      Json?
  positions   VillainProfilePosition[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}

model VillainProfilePosition {
  id        String         @id @default(cuid())
  profileId String
  profile   VillainProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  position  Int
  hands     Json

  @@unique([profileId, position])
  @@index([profileId])
}
